# ─── Tonalli API ───────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ────────────────────────────────────
DATABASE_URL=postgresql://tonalli:tonalli_secret@localhost:5432/tonalli?schema=public

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO (S3-compatible storage) ─────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=tonalli_minio
MINIO_SECRET_KEY=tonalli_minio_secret
MINIO_BUCKET=tonalli-assets
MINIO_USE_SSL=false

# ─── CORS ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:8082

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── App URLs ──────────────────────────────────────
MENU_BASE_URL=http://localhost:8082
API_BASE_URL=http://localhost:3000

# ─── Yesswera Integration ─────────────────────────
YESSWERA_REGISTRATION_KEY=change-me-shared-key-with-yesswera
